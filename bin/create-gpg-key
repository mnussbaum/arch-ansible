#!/bin/bash
# Creates a new GPG key and programs any number of YubiKeys.
#
# Usage: bin/create-gpg-key <device>
#
# <device>: USB block device to format and encrypt (e.g. /dev/sdb).
#           WARNING: this wipes the device.
#
# The key UID is read from the Ansible variable user.gpg_key_uid.
# After completion:
#   - files/gpg-pubkey.asc is written (commit it)
#   - <device> holds primary-key.asc and revocation-cert.asc (store offline)
#
# Run bin/renew-gpg-subkeys annually to extend subkey expiry.

set -o errexit
set -o nounset
set -o pipefail

source bin/_gpg_common.sh

DEVICE="${1:?Usage: $0 <device>}"

KEY_UID=$(yq -r '.user.gpg_key_uid' group_vars/all/vars.yml)
if [[ -z "$KEY_UID" || "$KEY_UID" == "null" ]]; then
  echo "Error: could not read user.gpg_key_uid from group_vars/all/vars.yml" >&2
  exit 1
fi

RENEWAL_HOME=$(mktemp -d)
SUBKEY_BACKUP=$(mktemp)

cleanup() {
  close_usb
  rm -rf "$RENEWAL_HOME"
  rm -f "$SUBKEY_BACKUP"
}
trap cleanup EXIT

setup_gnupghome "$RENEWAL_HOME"
export GNUPGHOME="$RENEWAL_HOME"

format_and_open_usb "$DEVICE"

echo "==> Creating primary key for: $KEY_UID"
"${GPG_BATCH[@]}" --quick-gen-key "$KEY_UID" ed25519 cert never

FINGERPRINT=$(gpg --list-keys --with-colons "$KEY_UID" | awk -F: '/^fpr/ { print $10; exit }')
echo "==> Fingerprint: $FINGERPRINT"

echo "==> Adding subkeys..."
"${GPG_BATCH[@]}" --yes --quick-add-key "$FINGERPRINT" ed25519 sign 1y
"${GPG_BATCH[@]}" --yes --quick-add-key "$FINGERPRINT" cv25519 encr 1y
"${GPG_BATCH[@]}" --yes --quick-add-key "$FINGERPRINT" ed25519 auth 1y

echo "==> Generating revocation certificate..."
printf 'y\n0\n\ny\n' | gpg --command-fd 0 --gen-revoke "$FINGERPRINT" > "$USB_MOUNT/revocation-cert.asc"
echo "    Store $DEVICE's revocation-cert.asc separately from the primary key."

echo "==> Backing up primary key to USB..."
"${GPG_BATCH[@]}" --armor --export-secret-keys "$FINGERPRINT" > "$USB_MOUNT/primary-key.asc"

echo "==> Exporting public key to files/gpg-pubkey.asc..."
gpg --armor --export "$FINGERPRINT" > files/gpg-pubkey.asc

echo "==> Creating subkey backup for YubiKey programming..."
"${GPG_BATCH[@]}" --armor --export-secret-subkeys "$FINGERPRINT" > "$SUBKEY_BACKUP"

program_all_yubikeys

echo "==> Enrolling auth subkey keygrip in group_vars/all/gpg_auth_keygrips.yml..."
KEYGRIP=$(gpg --with-keygrip --list-keys "$FINGERPRINT" | \
  awk '/\[A\]/{found=1} found && /Keygrip/{print $NF; exit}')
python3 - "$KEYGRIP" <<'PYEOF'
import sys, yaml
keygrip = sys.argv[1]
filepath = 'group_vars/all/gpg_auth_keygrips.yml'
with open(filepath) as f:
    data = yaml.safe_load(f) or {}
keygrips = data.setdefault('gpg_auth_ssh_keygrips', [])
if keygrip not in keygrips:
    keygrips.append(keygrip)
    with open(filepath, 'w') as f:
        yaml.dump(data, f, default_flow_style=False)
PYEOF

echo "    Fingerprint: $FINGERPRINT"
echo ""
echo "Next steps:"
echo "  1. Add the SSH public key to GitHub/GitLab:"
echo "       gpg --export-ssh-key $FINGERPRINT"
echo "  2. Commit the public key and keygrips:"
echo "       git add files/gpg-pubkey.asc group_vars/all/gpg_auth_keygrips.yml"
echo "       git commit -m 'Add GPG public key'"
