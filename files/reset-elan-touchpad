#!/bin/sh
# Rebind the Elan i2c touchpad after resume. Without this, pointer movement
# works but clicking is delayed ~1-2 minutes while the touchpad firmware
# reinitializes its button reporting path.

set -o errexit
set -o nounset
set -o pipefail

log() {
    logger -t reset-elan-touchpad "$*"
}

graphical_user() {
    loginctl list-sessions --no-legend \
        | awk '$3 != "" {print $3; exit}'
}

case "$1" in
    post)
        driver=/sys/bus/i2c/drivers/i2c_hid_acpi
        rebound=0
        for dev in "$driver"/*/; do
            [ -L "${dev%/}/driver" ] || continue
            devid=$(basename "$dev")
            log "post: rebinding $devid"
            echo "$devid" > "$driver/unbind"
            sleep 0.3
            echo "$devid" > "$driver/bind"
            rebound=$((rebound + 1))
        done
        log "post: rebound $rebound device(s)"
        # Kill libinput-gestures so systemd restarts it fresh via
        # Restart=on-failure, picking up the newly rebound device.
        # D-Bus is unreliable in the post-resume system hook context so we
        # avoid systemctl and let systemd handle the restart automatically.
        user=$(graphical_user) || true
        if [ -n "$user" ]; then
            pid=$(pgrep -f -u "$user" libinput-gestures 2>/dev/null) || true
            if [ -n "$pid" ]; then
                log "post: killing libinput-gestures pid=$pid (user=$user)"
                kill -9 $pid && log "post: killed, systemd will restart fresh"
            else
                log "post: libinput-gestures not running as $user (stopped or failed — check 'systemctl --user status libinput-gestures')"
            fi
        else
            log "post: no graphical user session found"
        fi
        ;;
esac
