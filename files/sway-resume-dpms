#!/bin/sh
# After resume from hibernate, i915 takes time to reinitialize the display
# pipeline, causing wlroots atomic commits to return EBUSY for several minutes.
# Toggling DPMS forces sway to do a full re-modeset once the GPU is ready,
# which unblocks rendering without disabling atomic modesetting.

set -o errexit
set -o nounset
set -o pipefail

log() {
    logger -t sway-resume-dpms "$*"
}

graphical_user() {
    loginctl list-sessions --no-legend \
        | awk '$3 != "" {print $3; exit}'
}

case "$1" in
    post)
        user=$(graphical_user) || true
        if [ -z "$user" ]; then
            log "post: no graphical user session found"
            exit 0
        fi
        uid=$(id -u "$user")
        swaysock=$(ls /run/user/"$uid"/sway-ipc.*.sock 2>/dev/null | head -1) || true
        if [ -z "$swaysock" ]; then
            log "post: no sway socket found for user=$user"
            exit 0
        fi
        log "post: scheduling DPMS toggle (user=$user)"
        # Run in background so the hook exits immediately and doesn't block resume.
        # Retry until sway accepts the command: sway re-acquires DRM devices ~13s
        # after resume, but our first attempt at ~6s gets a quick error response.
        (
            attempt=0
            while [ "$attempt" -lt 20 ]; do
                attempt=$((attempt + 1))
                sleep 3
                if su -c "swaymsg -s '$swaysock' 'output * dpms off'" "$user" 2>/dev/null; then
                    logger -t sway-resume-dpms "post: dpms off succeeded (attempt $attempt)"
                    sleep 1
                    su -c "swaymsg -s '$swaysock' 'output * dpms on'" "$user" \
                        || logger -t sway-resume-dpms "post: dpms on failed"
                    logger -t sway-resume-dpms "post: DPMS toggle complete"
                    exit 0
                fi
                logger -t sway-resume-dpms "post: dpms off not ready (attempt $attempt), retrying"
            done
            logger -t sway-resume-dpms "post: dpms toggle failed after 20 attempts"
        ) &
        ;;
esac
